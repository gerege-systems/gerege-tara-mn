# Production нууцууд — энэ файлыг .env болгон хуулж, утгуудыг солино.
# .env-ийг git-д commit ХИЙХГҮЙ (gitignore-д орсон).
POSTGRES_PASSWORD=change-me-strong
HYDRA_SECRET=change-me-at-least-32-characters-long
HYDRA_SALT=change-me-random-salt
DEMO_CLIENT_SECRET=change-me-demo-secret

# Админ порталын нэвтрэлт (https://dan.dgov.mn/admin)
DAN_ADMIN_USER=admin
DAN_ADMIN_PASSWORD=change-me-strong-admin-password
