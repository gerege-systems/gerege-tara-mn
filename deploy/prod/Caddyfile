# ДАН — Caddy reverse proxy (dan.dgov.mn) — автомат HTTPS (Let's Encrypt)

dan.dgov.mn {
	encode gzip

	# Аюулгүй байдлын header-ууд
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# OIDC цөмийн нийтийн endpoint-ууд → Hydra public (4444)
	@hydra path /oauth2/* /.well-known/* /userinfo /userinfo/* /health/*
	handle @hydra {
		reverse_proxy hydra:4444
	}

	# Бусад бүх зам (нүүр, /auth/*, /demo/*, /actuator) → dan-login (3000)
	handle {
		reverse_proxy dan-login:3000
	}
}
